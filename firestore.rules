rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description This ruleset enforces a user-ownership model for player data,
     *              allowing only the player to read, update, or delete their own data.
     * @dataStructure All player data is stored under the /players/{playerId} path.
     * @keySecurityDecisions User listing is disallowed. Data validation is minimal for prototyping.
     */

    // Helper function to determine if the request is from a signed-in user.
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to determine if the user ID matches the requested user ID.
    function isOwner(playerId) {
      return isSignedIn() && request.auth.uid == playerId;
    }

    // Helper function to check if the user is the existing owner of the document.
    function isExistingOwner(playerId) {
      return isOwner(playerId) && resource != null;
    }

    /**
     * @description Controls access to individual player documents.
     * @path /players/{playerId}
     * @allow (get) Authenticated user accessing their own player document.
     * @allow (create) Authenticated user creating their own player document.
     * @allow (update) Authenticated user updating their own player document.
     * @allow (delete) Authenticated user deleting their own player document.
     * @deny (get) Authenticated user accessing a different player document.
     * @deny (create) Authenticated user creating a player document with mismatched ID.
     * @deny (update) Authenticated user updating a different player document.
     * @deny (delete) Authenticated user deleting a different player document.
     * @principle Enforces document ownership for all read and write operations.
     */
    match /players/{playerId} {
      allow get: if isOwner(playerId);
      allow list: if false;

      allow create: if isOwner(playerId);
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }
}