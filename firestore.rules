/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset focuses on securing player data. All players are anonymous.
 * It ensures only authenticated users can update their own player documents.
 *
 * Data Structure:
 * - /players/{playerId}: Stores player information. The `playerId` matches the user's `auth.uid`.
 *
 * Key Security Decisions:
 * - Players can only update their own player documents.
 * - Data validation is relaxed to enable rapid prototyping. Only essential auth checks are performed.
 * - The rules implicitly trust the server-side logic to maintain game state and enforce fair play.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /players/{playerId} collection.
     * @path /players/{playerId}
     * @allow (update) User with UID 'Y9U1YvBBHRXr3wNrKWjE3CvNaL02' can update the document with ID 'Y9U1YvBBHRXr3wNrKWjE3CvNaL02'.
     * @deny (update) User with UID 'otherUserId' cannot update the document with ID 'Y9U1YvBBHRXr3wNrKWjE3CvNaL02'.
     * @principle Enforces document ownership for writes.
     */
    match /players/{playerId} {
      allow get: if true;
      allow list: if false;
      allow create: if false;
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }

  // Helper functions
  function isSignedIn() {
    return request.auth != null;
  }

  function isOwner(userId) {
    return isSignedIn() && request.auth.uid == userId;
  }

  function isExistingOwner(userId) {
    return isOwner(userId) && resource != null;
  }
}