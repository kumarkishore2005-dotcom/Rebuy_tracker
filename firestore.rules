/**
 * @file Firestore Security Rules for Poker Game
 * @corePhilosophy This ruleset enforces a strict user-ownership model for player data.
 * @dataStructure All player data is stored under the /players/{playerId} path.
 * @keySecurityDecisions Only the player can read or write their own data. No listing of all players is allowed. Data shape validation is relaxed for prototyping.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows a player to read, create, update, and delete their own player data.
     * @path /players/{playerId}
     * @allow (get, create, update, delete) if request.auth.uid == playerId
     * @deny (get, create, update, delete) if request.auth.uid != playerId
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      allow get: if isSignedIn() && isOwner(playerId);
      allow list: if false; // Listing all players is disallowed

      allow create: if isSignedIn() && request.auth.uid == playerId;
      allow update: if isSignedIn() && isExistingOwner(playerId);
      allow delete: if isSignedIn() && isExistingOwner(playerId);
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(playerId) {
      return request.auth.uid == playerId;
    }

    function isExistingOwner(playerId) {
      return isSignedIn() && isOwner(playerId) && resource != null;
    }
  }
}