/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset allows anyone to read player data and allows authenticated users to create, update and delete their own player data.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Anonymous authentication is enabled.
 * - Players can only manage their own data.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Rules for the /players/{playerId} collection.
     * @path /players/{playerId}
     * @allow (get, list): Anyone can read player data.
     * @allow (create): An authenticated user can create their own player document if the ID matches their auth UID.
     * @allow (update, delete): An authenticated user can update or delete their own player document.
     * @deny (create): An authenticated user cannot create a player document with an ID that does not match their auth UID.
     * @deny (update, delete): An authenticated user cannot update or delete a player document that does not belong to them.
     * @principle Enforces document ownership for writes; allows public reads.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == playerId;
      allow update, delete: if isSignedIn() && isExistingOwner(playerId);
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the document.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the existing document.
     * @param {string} userId The user ID to check against.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}