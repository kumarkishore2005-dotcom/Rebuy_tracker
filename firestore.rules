/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset adopts a public-read, owner-write model for player data.  All players are publicly visible.
 *
 * Data Structure:
 * Player data is stored in the top-level `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Players are publicly listable and readable via `get` and `list`.
 * - Only the owner (creator) can create, update, or delete a player document.
 * - Assumes `createdAt` are set server-side (via Firebase Functions or similar).
 *
 * Denormalization for Authorization:
 *  - The app does not require denormalization for authorization, as all player documents are public read.
 *
 * Structural Segregation:
 *  - No structural segregation is used, because it is not specified in the requirements.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read player data, but only the creator can modify it.
     * @path /players/{playerId}
     * @allow (get, list) Anyone can read a player's information.
     * @allow (create) The user with auth.uid can create a new player.
     * @allow (update, delete) The user with auth.uid can update/delete their own player document.
     * @deny Any unauthorized user cannot create, update, or delete player data.
     * @principle Enforces public read access with owner-only writes.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn()
                    && request.resource.data.name is string
                    && request.resource.data.rebuys is number
                    && request.resource.data.blackCoins is number
                    && request.resource.data.createdAt is map; // relax the rules for timestamp in create
      allow update, delete: if isSignedIn() && request.auth.uid == resource.data.uid;
    }
  }

  function isSignedIn() {
    return request.auth != null;
  }
}