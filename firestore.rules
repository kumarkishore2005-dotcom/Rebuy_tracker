/**
 * @file Firebase Security Rules for Firestore.
 *
 * @core_philosophy This ruleset is in prototyping mode, prioritizing strong
 *   authorization over strict data validation to allow for rapid development.
 *   It enforces that only authenticated users can create player documents,
 *   and does not currently restrict data based on its contents.
 *
 * @data_structure Data is stored in a flat collection at the root: `/players/{playerId}`.
 *
 * @key_security_decisions
 *   - Users can only create their own player documents.
 *   - No listing of players by other users is allowed.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows authenticated users to create player documents.
     * @path /players/{playerId}
     * @allow (create) - An authenticated user with a valid `auth.uid` can create a player document.
     * @deny (create) - An unauthenticated user (no `auth.uid`) cannot create a player document.
     * @principle Enforces authentication for creating player documents.
     */
    match /players/{playerId} {
      allow get: if false;
      allow list: if false;

      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
  }
}