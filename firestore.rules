/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset prioritizes secure data access based on user authentication.
 * All write operations require a valid authenticated user. Read operations are public.
 *
 * Data Structure:
 * The Firestore database consists of a single top-level collection, `/players/{playerId}`,
 * where each document represents a player in the game.
 *
 * Key Security Decisions:
 * - Players can be listed by anyone
 * - Data shape is not strictly enforced during this prototyping phase.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to individual player documents.
     * @path /players/{playerId}
     * @allow (get, list): Any user can read any player's information.
     * @allow (create, update, delete): Only authenticated users can modify player data.
     * @deny (create, update, delete): Operations attempted by unauthenticated users.
     * @principle Allows listing and getting documents. Authenticated user has write access.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
  }
}