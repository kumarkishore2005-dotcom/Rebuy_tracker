/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model, where each player can only manage their own player document.
 *
 * Data Structure:
 * All player data is stored in the `/players/{playerId}` collection, where `{playerId}` is the unique ID of the player.
 *
 * Key Security Decisions:
 * - Players can only create their own player document with their own ID.
 * - Players can only read, update, and delete their own player document.
 * - Listing the `/players` collection is disallowed to prevent unauthorized data access.
 *
 * Denormalization for Authorization:
 * - The player ID is included in the document path (`/players/{playerId}`) and must match the authenticated user's UID. This enables efficient ownership checks without additional reads.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to player documents.
     * @path /players/{playerId}
     * @allow (create) User with UID 'user_abc' can create a player document with ID 'user_abc'.
     * @deny (create) User with UID 'user_abc' cannot create a player document with ID 'user_xyz'.
     * @allow (get) User with UID 'user_abc' can get their own player document with ID 'user_abc'.
     * @deny (get) User with UID 'user_abc' cannot get a player document with ID 'user_xyz'.
     * @allow (update) User with UID 'user_abc' can update their own player document with ID 'user_abc'.
     * @deny (update) User with UID 'user_abc' cannot update a player document with ID 'user_xyz'.
     * @allow (delete) User with UID 'user_abc' can delete their own player document with ID 'user_abc'.
     * @deny (delete) User with UID 'user_abc' cannot delete a player document with ID 'user_xyz'.
     * @deny (list) No one can list all player documents.
     * @principle Enforces document ownership for all operations on player documents.
     */
    match /players/{playerId} {
      // Helpers
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(playerId) {
        return isSignedIn() && request.auth.uid == playerId;
      }

      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      // Permissions
      allow get: if isOwner(playerId);
      allow list: if false;
      allow create: if isOwner(playerId);
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }
}