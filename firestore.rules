/**
 * @fileoverview Firestore Security Rules for the poker game application.
 *
 * Core Philosophy:
 * This ruleset adopts a permissive security posture, allowing any authenticated user to create, read, and list player documents.
 *
 * Data Structure:
 * All player data is stored in the top-level `/players/{playerId}` collection.
 *
 * Key Security Decisions:
 * - Player listing is public, meaning any logged-in user can see all players.
 * - Schema validation is relaxed for prototyping purposes.
 * - Player creation is allowed for any authenticated user.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows any authenticated user to create, read, update, and delete player documents.
     * @path /players/{playerId}
     * @allow (create) User with any valid auth can create a player document.
     * @allow (get) Any authenticated user can read any player document.
     * @allow (list) Any authenticated user can list player documents.
     * @allow (update) Any authenticated user can update any player document.
     * @allow (delete) Any authenticated user can delete any player document.
     * @deny (create) Unauthenticated users cannot create player documents.
     * @deny (update) Unauthenticated users cannot update player documents.
     * @deny (delete) Unauthenticated users cannot delete player documents.
     * @principle Allows any authenticated user to perform all operations on player documents.
     */
    match /players/{playerId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // Helper function to check if the user is signed in.
    function isSignedIn() {
      return request.auth != null;
    }
  }
}