/**
 * @file Firestore Security Rules
 * @core_philosophy This ruleset enforces a user-ownership model for player data. Each player can only read, update, or delete their own player document.
 * @data_structure All player data is stored under the `/players/{playerId}` path.
 * @key_security_decisions Players can only access their own documents, and cannot list all players.
 * @denormalization For simplicity and performance, authorization relies on the `playerId` path parameter matching the authenticated user's UID. No data denormalization is required in this simple example.
 * @structural_segregation There is no segregation of public vs. private data. All player data is considered private.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to player documents.
     * @path /players/{playerId}
     * @allow (create) - A player can create their own document if the `playerId` matches their `auth.uid`.
     * @allow (get, update, delete) - A player can read, update, or delete their own document if the `playerId` matches their `auth.uid`.
     * @deny (create) - A player cannot create a document with a `playerId` that does not match their `auth.uid`.
     * @deny (get, update, delete) - A player cannot read, update, or delete another player's document.
     * @principle Enforces document ownership for all operations.
     */
    match /players/{playerId} {
      // Helpers
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(playerId) {
        return isSignedIn() && request.auth.uid == playerId;
      }

      function isExistingOwner(playerId) {
        return isOwner(playerId) && resource != null;
      }

      // Permissions
      allow get: if isOwner(playerId);
      allow list: if false; // Players cannot list all player documents.
      allow create: if isOwner(playerId);
      allow update: if isExistingOwner(playerId);
      allow delete: if isExistingOwner(playerId);
    }
  }
}