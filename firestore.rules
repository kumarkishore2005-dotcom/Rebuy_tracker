/**
 * @file Firestore Security Rules for Rebuy Tracker.
 *
 * @core_philosophy This ruleset provides public read access to player data, but restricts write access.
 *  This is a public read with owner-only writes pattern.
 * @data_structure The database stores player data in the `/players/{playerId}` collection.
 * @key_security_decisions All `players` are publicly readable but protected via a simple ownership model.
 *
 * @denormalization None.
 * @structural_segregation None.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls read and write access to individual player documents.
     * @path /players/{playerId}
     * @allow (get, list): Any user can read player data.
     * @allow (create): Only allowed if the playerId matches the authenticated user's UID.
     * @allow (update, delete): Only allowed if the playerId matches the authenticated user's UID and the document exists.
     * @deny (create): If the playerId does not match the authenticated user's UID.
     * @deny (update, delete): If the playerId does not match the authenticated user's UID, or if the document does not exist.
     * @principle Enforces public read access with owner-only writes based on document ID.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == playerId;
      allow update, delete: if isSignedIn() && isExistingOwner(playerId);
    }

    // Helper functions

    /**
     * @description Checks if the user is signed in.
     * @return True if the user is authenticated, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the document.
     * @param userId The user ID to check against the request's authentication UID.
     * @return True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the document, and that the document exists.
     * @param userId The user ID to check against the resource path.
     * @return True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }
  }
}