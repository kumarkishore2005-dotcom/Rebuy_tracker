/**
 * @description This ruleset enforces a public read, owner-write model for player data.
 * @dataStructure The database stores player information under the `/players/{playerId}` path.
 * @keySecurityDecisions All player data is publicly readable, but only the creator can modify or delete it.  There is no user listing allowed.
 * @denormalizationForAuthorization The `Player` entity is expected to contain the uid of the creating user, `request.auth.uid`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read player data, but restricts modifications to the creator.
     * @path /players/{playerId}
     * @allow (get, list): Any user can read the `Player` documents.
     * @allow (create): Only the authenticated user whose UID matches the `playerId` can create the document. Requires that `request.resource.data.creatorId` must equal `request.auth.uid`.
     * @allow (update, delete): Only the authenticated user who created the document can update or delete it.
     * @deny The user who is not the creator.
     * @principle Enforces a public read, owner-write access control model for player data.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.auth.uid == playerId;
      allow update, delete: if isSignedIn() && isExistingOwner(playerId);
    }

    //----------------------------------------------------------------------------------------------
    // Helper functions
    //----------------------------------------------------------------------------------------------

    /**
     * @description Checks if the user is signed in.
     * @return `true` if the user is signed in, `false` otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the document based on the `playerId`.
     * @param playerId The ID of the player document.
     * @return `true` if the user is the owner, `false` otherwise.
     */
    function isOwner(playerId) {
      return request.auth.uid == playerId;
    }

     /**
      * @description Checks if the user is the owner of an existing document based on the playerId.
      * @param playerId The ID of the player document.
      * @return `true` if the user is the owner and the document exists, `false` otherwise.
      */
    function isExistingOwner(playerId) {
      return isOwner(playerId) && resource != null;
    }
  }
}