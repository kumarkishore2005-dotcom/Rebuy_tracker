/**
 * @fileoverview Firestore Security Rules for the Poker Game application.
 *
 * This ruleset secures a multi-table poker game application.
 * Data is structured with a top-level 'tables' collection, where each table
 * document can contain a 'players' subcollection.
 *
 * Key Security Decisions:
 * - Public Read Access: All users (authenticated or not) can read table and player data.
 *   This is suitable for a non-sensitive game where standings are public.
 * - Authenticated Writes: Only authenticated users (via anonymous auth) can create,
 *   update, or delete tables and players. This prevents unauthorized modification
 *   of game state.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /tables/{tableId} {
      // Allow anyone to see the list of tables, but only signed-in users to create/delete them.
      allow read: if true;
      allow write: if isSignedIn();

      // Rules for the 'players' subcollection within each table.
      match /players/{playerId} {
        // Allow anyone to read player data, but only signed-in users to modify it.
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }
  }
}
