/**
 * @fileoverview Firestore Security Rules for Rebuy Tracker.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for user profiles and allows dealers (authenticated users)
 * to manage player data. It prioritizes security by default, explicitly denying access where not specifically granted.
 *
 * Data Structure:
 * - /users/{userId}: Stores profile information for each user, secured by owner-only access.
 * - /players/{playerId}: Stores player data, accessible to authenticated dealers (any logged-in user).
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Dealers (authenticated users) can create, update, and delete player data.
 * - Listing users is explicitly denied to prevent information disclosure.
 * - The rules are permissive on data shapes to allow rapid prototyping, but enforce critical authorization checks.
 *
 * Denormalization for Authorization:
 * Not applicable in this simplified model.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (get, create, update, delete): Authenticated user with matching UID.
     * @deny (get, create, update, delete): Unauthenticated user or mismatched UID.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
          return isOwner(userId) && exists(resource.data);
      }

      allow get: if isSignedIn() && isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Controls access to player information.
     * @path /players/{playerId}
     * @allow (get, list): Any authenticated user.
     * @allow (create, update, delete): Any authenticated user.
     * @deny (create, update, delete): Unauthenticated user.
     */
    match /players/{playerId} {
      function isSignedIn() {
        return request.auth != null;
      }
        allow get, list: if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && exists(resource.data);
        allow delete: if isSignedIn() && exists(resource.data);
    }
  }
}